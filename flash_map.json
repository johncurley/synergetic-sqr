{
    "nodes": {
        "seed": {
            "description": "Minimal Resonant Node (<100 LUTs)",
            "modules": ["spu_seed_heart.v", "spu_base_manifold.v"],
            "constraints": "minimal.pcf"
        },
        "sentinel": {
            "description": "Autonomous Bio-Guardian (~800 LUTs)",
            "modules": ["spu_seed_heart.v", "spu_hardware_inference.v", "spu_bio_filter.v", "spu_laminar_phy.v"],
            "constraints": "nano.pcf"
        },
        "cortex": {
            "description": "Full Dual-Core Fleet Integrator (~4.5k LUTs)",
            "modules": ["spu_resonant_heart.v", "spu_gemini_manifold.v", "spu_ssd1306_driver.v", "spu_active_inference.v"],
            "constraints": "icesugar.pcf"
        },
        "game_hub": {
            "description": "High-Fi Gaming & World Resolver (~25k+ LUTs)",
            "modules": [
                "spu_gemini_manifold.v", 
                "spu_multi_core_gpu.v", 
                "spu_world_resolver.v", 
                "spu_gamepad_bridge.v", 
                "spu_dream_log_ext.v", 
                "spu_artery_to_ip.v", 
                "spu_pwm_audio_stereo.v"
