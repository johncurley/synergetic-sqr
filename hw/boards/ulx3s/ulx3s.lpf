# SPU-13 Unified Constraints: ULX3S (ECP5-85F)
# v1.1 HAL Mapping

# --- 1. Resonant Pulse (Clock) ---
LOCATE COMP "clk_phys" SITE "G2";
IOBUF PORT "clk_phys" IO_TYPE=LVCMOS33;

# --- 2. Temporal Anchor (Reset) ---
# Mapping btn[0] to rst_phys_n
LOCATE COMP "rst_phys_n" SITE "R1";
IOBUF PORT "rst_phys_n" IO_TYPE=LVCMOS33;

# --- 3. Janus Status Display (RGB LED) ---
# Mapping 3 onboard LEDs to RGB logicals
LOCATE COMP "led_sat_red" SITE "B2";
IOBUF PORT "led_sat_red" IO_TYPE=LVCMOS33;
LOCATE COMP "led_sat_grn" SITE "C2";
IOBUF PORT "led_sat_grn" IO_TYPE=LVCMOS33;
LOCATE COMP "led_sat_blu" SITE "C1";
IOBUF PORT "led_sat_blu" IO_TYPE=LVCMOS33;

# --- 4. Command & Control (UART) ---
LOCATE COMP "uart_phys_tx" SITE "L4";
IOBUF PORT "uart_phys_tx" IO_TYPE=LVCMOS33;
LOCATE COMP "uart_phys_rx" SITE "M1";
IOBUF PORT "uart_phys_rx" IO_TYPE=LVCMOS33;

# --- 5. THE SOUL (SPI Flash) ---
LOCATE COMP "flash_cs_n" SITE "D2";
IOBUF PORT "flash_cs_n" IO_TYPE=LVCMOS33;
LOCATE COMP "flash_sck" SITE "E12";
IOBUF PORT "flash_sck" IO_TYPE=LVCMOS33;
LOCATE COMP "flash_mosi" SITE "E2";
IOBUF PORT "flash_mosi" IO_TYPE=LVCMOS33;
LOCATE COMP "flash_miso" SITE "F2";
IOBUF PORT "flash_miso" IO_TYPE=LVCMOS33;
