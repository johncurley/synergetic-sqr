# TinyFPGA BX SPU-13 Constraints
# v3.4.3 "Physical Metabolic Mapping"

# --- 1. Resonant Clock Entry ---
set_io clk B2

# --- 2. Status Display ---
set_io pin_led B3

# --- 3. Proprioceptive Entry (Nervous Antenna) ---
set_io bias_in A5

# --- 4. I2C OLED (Visual Reification) ---
set_io oled_scl A6
set_io oled_sda B6

# --- 5. Metabolic Sense (12-bit Shunt ADC) ---
set_io adc_in[0]  H9
set_io adc_in[1]  G8
set_io adc_in[2]  H8
set_io adc_in[3]  J8
set_io adc_in[4]  H7
set_io adc_in[5]  J7
set_io adc_in[6]  G5
set_io adc_in[7]  H5
set_io adc_in[8]  J5
set_io adc_in[9]  G4
set_io adc_in[10] H4
set_io adc_in[11] J4

# --- 5. Command & Control (UART) ---
# Striking the IVM Lattice via Serial Keyboard
set_io uart_tx A2
set_io uart_rx A1

# Disable USB
set_io usb_p B4
set_io usb_n A4
set_io usb_pu A3
