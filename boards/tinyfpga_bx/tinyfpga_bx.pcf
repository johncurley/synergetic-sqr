# TinyFPGA BX SPU-13 Constraints
# v3.3.95 "Proprioceptive Sensing"

# --- 1. Resonant Clock Entry ---
set_io clk B2

# --- 2. Status Display ---
set_io pin_led B3

# --- 3. Proprioceptive Entry (Nervous Antenna) ---
set_io bias_in A5

# --- 4. Command & Control (UART) ---
# Striking the IVM Lattice via Serial Keyboard
set_io uart_tx A2
set_io uart_rx A1

# Disable USB
set_io usb_p B4
set_io usb_n A4
set_io usb_pu A3
