// Tang Nano 20K Physical Constraints (v2.9.30)
// Target: Gowin GW2AR-LV18QN88C8/I7

// 1. System Clock (27MHz)
IO_LOC "clk_27mhz" 4;
IO_PORT "clk_27mhz" IO_TYPE=LVCMOS33;

// 2. Global Reset (Button S1)
IO_LOC "btn_rst_n" 88;
IO_PORT "btn_rst_n" IO_TYPE=LVCMOS33;

// 3. Status LEDs
IO_LOC "led[0]" 15;
IO_LOC "led[1]" 16;
IO_LOC "led[2]" 17;
IO_LOC "led[3]" 18;
IO_LOC "led[4]" 19;
IO_LOC "led[5]" 20;

// 4. UART TX (Pin 69)
IO_LOC "uart_tx" 69;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33;
