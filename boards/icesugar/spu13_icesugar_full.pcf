# SPU-13 Full Manifold Constraints: iCeSugar (iCE40UP5K)
# v3.4.37 "Golden Reification Mapping"
# Objective: Physical realization of the interactive visual manifold.

# --- 1. Resonant Clock Entry ---
set_io clk_12mhz 35

# --- 2. Manual Reset & Throttle ---
set_io rst_n 18
set_io laminar_en 11

# --- 3. Sensory Interaction (The Skin) ---
# Nervous Antenna (Proprioceptive Bias)
set_io bias_in 12
# Metabolic Sense (12-bit Shunt ADC)
set_io adc_in 13

# --- 4. Visual Manifestation (I2C OLED) ---
# SSD1306 128x64 Display
set_io oled_scl 44
set_io oled_sda 45

# --- 5. Status Display (RGB LED) ---
set_io led_sat_red   39
set_io led_sat_grn 40
set_io led_sat_blu  41

# --- 6. Command & Control (UART) ---
# Interactive Strike Path (Keyboard)
set_io uart_tx 10
set_io uart_rx 9

# --- 7. Janus-Gate Differential Output ---
# Optional: Twisted-pair monitor pins
set_io -current 6 janus_pos 46
set_io -current 6 janus_neg 47
