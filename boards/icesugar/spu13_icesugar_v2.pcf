# SPU-13 Unified Constraints: iCeSugar Nano (iCE40UP5K)
# v1.1 HAL Mapping

# --- 1. Resonant Pulse (Clock) ---
set_io clk_phys 35

# --- 2. Temporal Anchor (Reset) ---
set_io rst_phys_n 18

# --- 4. Janus Status Display (RGB LED) ---
set_io led_sat_red 39
set_io led_sat_grn 40
set_io led_sat_blu 41

# --- 5. OLED Interface (PMOD C) ---
set_io oled_scl 43
set_io oled_sda 38

# --- 6. Command & Control (UART) ---

set_io uart_phys_tx 10
set_io uart_phys_rx 9

# --- 5. Metabolic Sense (Sensing) ---
set_io adc_phys_in 13
set_io bias_phys_in 12
